{
  "name": "re-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:rescript\" \"npm:dev:vite\"",
    "dev:rescript": "rescript watch",
    "dev:vite": "vite --host 0.0.0.0 --port 2091 --strictPort",
    "build": "rescript && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 2091 --strictPort",
    "clean": "rescript clean"
  },
  "dependencies": {
    "@rescript/react": "^0.14.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "rescript": "^12.2.0",
    "vite": "^8.0.8"
  }
}
